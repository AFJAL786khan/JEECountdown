<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:paddingLeft="40dp"
        android:paddingRight="40dp">

        <!-- LEFT COLUMN: Title + big counters -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:paddingRight="20dp">

            <!-- TAG -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◆  JEE MAIN SESSION 1  ◆"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:textColor="@color/accent"
                android:background="@drawable/tag_border"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="6dp" android:paddingBottom="6dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JEE 2027"
                android:textSize="72sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Countdown to January 2027"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="@color/muted"
                android:layout_marginBottom="28dp" />

            <!-- Days + Hours -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginRight="6dp" android:background="@drawable/card_border" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_days" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="000" android:textSize="60sp" android:textStyle="bold" android:fontFamily="monospace" android:textColor="@color/accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DAYS" android:fontFamily="monospace" android:textSize="11sp" android:letterSpacing="0.2" android:textColor="@color/muted" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginLeft="6dp" android:background="@drawable/card_border" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_hours" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="60sp" android:textStyle="bold" android:fontFamily="monospace" android:textColor="@color/accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOURS" android:fontFamily="monospace" android:textSize="11sp" android:letterSpacing="0.2" android:textColor="@color/muted" />
                </LinearLayout>
            </LinearLayout>

            <!-- Minutes + Seconds -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginRight="6dp" android:background="@drawable/card_border" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_minutes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="60sp" android:textStyle="bold" android:fontFamily="monospace" android:textColor="@color/accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MINUTES" android:fontFamily="monospace" android:textSize="11sp" android:letterSpacing="0.2" android:textColor="@color/muted" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginLeft="6dp" android:background="@drawable/card_border" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tv_seconds" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="60sp" android:textStyle="bold" android:fontFamily="monospace" android:textColor="@color/accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SECONDS" android:fontFamily="monospace" android:textSize="11sp" android:letterSpacing="0.2" android:textColor="@color/muted" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- RIGHT COLUMN: Weeks/Months + info + quote -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:orientation="vertical"
            android:paddingLeft="20dp">

            <!-- Weeks -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginBottom="10dp" android:background="@drawable/card_border_orange" android:gravity="center_vertical" android:orientation="horizontal" android:paddingLeft="20dp">
                <TextView android:id="@+id/tv_weeks" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:textColor="@color/accent2" android:layout_marginRight="16dp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WEEKS" android:fontFamily="monospace" android:textSize="11sp" android:letterSpacing="0.2" android:textColor="@color/muted" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="remaining" android:textSize="13sp" android:textColor="@color/muted" />
                </LinearLayout>
            </LinearLayout>

            <!-- Months -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginBottom="16dp" android:background="@drawable/card_border_orange" android:gravity="center_vertical" android:orientation="horizontal" android:paddingLeft="20dp">
                <TextView android:id="@+id/tv_months" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:textColor="@color/accent2" android:layout_marginRight="16dp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MONTHS" android:fontFamily="monospace" android:textSize="11sp" android:letterSpacing="0.2" android:textColor="@color/muted" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="remaining" android:textSize="13sp" android:textColor="@color/muted" />
                </LinearLayout>
            </LinearLayout>

            <!-- Exam date -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/card_border" android:orientation="vertical" android:paddingLeft="20dp" android:paddingRight="20dp" android:paddingTop="14dp" android:paddingBottom="14dp" android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TARGET EXAM DATE" android:fontFamily="monospace" android:textSize="10sp" android:textColor="@color/muted" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="JAN 22, 2027  ● Session 1" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" android:textColor="@color/accent3" />
            </LinearLayout>

            <!-- Progress -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="PREP PROGRESS" android:fontFamily="monospace" android:textSize="10sp" android:textColor="@color/muted" />
                <TextView android:id="@+id/tv_progress_pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0% elapsed" android:fontFamily="monospace" android:textSize="10sp" android:textColor="@color/muted" />
            </LinearLayout>

            <ProgressBar android:id="@+id/progress_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/progress_drawable" android:layout_marginBottom="20dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginBottom="16dp" />

            <!-- Quote -->
            <TextView android:id="@+id/tv_quote" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="⚡  Every second counts" android:fontFamily="monospace" android:textSize="13sp" android:textColor="@color/accent" android:gravity="center" android:layout_marginBottom="20dp" />

            <!-- Credit -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CRAFTED BY  AFZAL KHAN  ·  JEE 2027" android:fontFamily="monospace" android:textSize="10sp" android:letterSpacing="0.12" android:textColor="@color/accent2" android:layout_gravity="center_horizontal" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
