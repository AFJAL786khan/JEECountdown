<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:gravity="center_horizontal">

        <!-- TAG + TITLE row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◆  JEE MAIN SESSION 1  ◆"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/accent"
                    android:background="@drawable/tag_border"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JEE 2027"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Countdown · Stay locked in"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:textColor="@color/muted" />
            </LinearLayout>

            <!-- Quote on right in landscape -->
            <TextView
                android:id="@+id/tv_quote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡  Every second counts"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="@color/accent"
                android:gravity="center" />

        </LinearLayout>

        <!-- ALL 6 units in one row: Days/Hours/Min/Sec/Weeks/Months -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <!-- DAYS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginRight="4dp"
                android:background="@drawable/card_border"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="000"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAYS"
                    android:fontFamily="monospace"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/muted" />
            </LinearLayout>

            <!-- HOURS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="@drawable/card_border"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOURS"
                    android:fontFamily="monospace"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/muted" />
            </LinearLayout>

            <!-- MINUTES -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="@drawable/card_border"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_minutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINUTES"
                    android:fontFamily="monospace"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/muted" />
            </LinearLayout>

            <!-- SECONDS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="@drawable/card_border"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_seconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SECONDS"
                    android:fontFamily="monospace"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/muted" />
            </LinearLayout>

            <!-- WEEKS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:background="@drawable/card_border_orange"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_weeks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent2" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WEEKS"
                    android:fontFamily="monospace"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/muted" />
            </LinearLayout>

            <!-- MONTHS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:background="@drawable/card_border_orange"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_months"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent2" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTHS"
                    android:fontFamily="monospace"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:textColor="@color/muted" />
            </LinearLayout>

        </LinearLayout>

        <!-- EXAM DATE BAR + PROGRESS in one row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Exam bar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                android:background="@drawable/card_border"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TARGET EXAM DATE"
                        android:fontFamily="monospace"
                        android:textSize="8sp"
                        android:textColor="@color/muted" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JAN 22, 2027"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:textColor="@color/accent3" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● LIVE"
                    android:fontFamily="monospace"
                    android:textSize="10sp"
                    android:textColor="@color/accent" />
            </LinearLayout>

            <!-- Progress -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PREP PROGRESS"
                        android:fontFamily="monospace"
                        android:textSize="8sp"
                        android:textColor="@color/muted" />
                    <TextView
                        android:id="@+id/tv_progress_pct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0% elapsed"
                        android:fontFamily="monospace"
                        android:textSize="8sp"
                        android:textColor="@color/muted" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_drawable" />
            </LinearLayout>

        </LinearLayout>

        <!-- CREDIT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRAFTED BY  AFZAL KHAN  ·  JEE 2027"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textColor="@color/accent2" />

    </LinearLayout>
</ScrollView>
